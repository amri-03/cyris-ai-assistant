# Cyris now supports Intelligent Fallback. You can specify up to 3 keys per provider.
# If a key runs out of credits (429 error), Cyris will automatically switch to the next one!

GROQ_API_KEY_1=your_groq_api_key_1
GROQ_API_KEY_2=your_groq_api_key_2
GROQ_API_KEY_3=your_groq_api_key_3

GEMINI_API_KEY_1=your_gemini_api_key_1
GEMINI_API_KEY_2=your_gemini_api_key_2
GEMINI_API_KEY_3=your_gemini_api_key_3

# AI_PROVIDER determines the default initial fallback layer, but Cyris will cross-route automatically.
AI_PROVIDER=groq

# Choose model for Gemini provider (e.g. gemini-2.5-flash, gemma-4-31b-it, gemma-4-26b-a4b-it)
GEMINI_MODEL=gemma-4-26b-a4b-it
